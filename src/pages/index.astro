---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { normalizeCategory } from '@/utils/blog'

import HeroSection from '@/components/blocks/hero-section/hero-section'
import ProfessionalJourney from '@/components/blocks/about/professional-journey'
import ArchitecturalPhilosophy from '@/components/blocks/about/architectural-philosophy'
import BlogCoverage from '@/components/blocks/about/blog-coverage'
import Blog from '@/components/blocks/blog-component/blog-component'

// Get all blog posts and convert to the format expected by components
const allPosts = await getCollection('blog')
const publishedPosts = allPosts

// Convert to the format expected by the React components
const allBlogPosts = publishedPosts
  .map((post, index) => ({
    id: post.data.id || index + 1,
    slug: post.data.slug || post.id,
    title: post.data.title,
    description: post.data.description,
    imageUrl: post.data.imageUrl || '/images/blog-post/post-1.webp',
    imageAlt: post.data.imageAlt || post.data.title,
    pubDate: post.data.pubDate,
    category: normalizeCategory(post.data.category),
    author: post.data.author,
    avatarUrl: post.data.avatarUrl || '/images/avatars/post-1.webp',
    readTime: post.data.readTime || 5,
    featured: post.data.featured || false
  }))
  .sort((a, b) => b.pubDate.localeCompare(a.pubDate))

// Page-specific SEO configuration
const pageTitle = 'Lakshya Tangri | Enterprise, Solution & Functional Architect'
const pageDescription =
  'Enterprise Architect specializing in technology strategy, digital transformation, and mission-critical platform governance across Defence, Government, and Finance.'
const pageKeywords =
  'Enterprise Architect, Solution Architect, Functional Architect, TOGAF 10, Technology Strategy, Digital Transformation, Architecture Governance, LeanIX, Sparx EA'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Lakshya Tangri | Enterprise Architect',
  description: pageDescription,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  },
  author: {
    '@type': 'Person',
    name: 'Lakshya Tangri'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <!--  All Sections -->
  <HeroSection blogData={allBlogPosts} client:load />
  <ArchitecturalPhilosophy client:load />
  <ProfessionalJourney client:load />
  <BlogCoverage client:load />
  <Blog blogData={allBlogPosts} client:load />
</Layout>
